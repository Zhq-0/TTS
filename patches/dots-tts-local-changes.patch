+    def _resolve_latent_stats_source(self, save_directory: Path) -> Path:
+        source = Path(self.latent_stats_path)
+        candidates = [source]
+        source_text = str(source)
+        if ".tmp" in source_text:
+            candidates.append(Path(source_text.replace(".tmp", "", 1)))
+
+        run_dir = save_directory.parent.parent
+        if run_dir.exists():
+            candidates.extend(
+                sorted(
+                    run_dir.glob(f"checkpoint-*/model/{self.LATENT_STATS_FILENAME}"),
+                    key=lambda path: path.stat().st_mtime,
+                    reverse=True,
+                )
+            )
+
+        for candidate in candidates:
+            if candidate.is_file():
+                self.latent_stats_path = candidate
+                self.core.io_helper = type(self.core.io_helper)(
+                    latent_stats_path=self.latent_stats_path
+                )
+                return candidate
+        raise FileNotFoundError(
+            f"Could not find {self.LATENT_STATS_FILENAME}; checked "
+            f"{[str(candidate) for candidate in candidates]}"
+        )
+
