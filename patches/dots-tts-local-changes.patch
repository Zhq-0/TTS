+class _MergedLoRALinear(nn.Module):
+    """Linear layer with LoRA adapters that saves as a merged standard Linear."""
+
+    def __init__(
+        self,
+        linear: nn.Linear,
+        *,
+        rank: int,
+        alpha: float,
+        dropout: float,
+    ) -> None:
+        super().__init__()
+        if rank <= 0:
+            raise ValueError(f"LoRA rank must be positive, got {rank}.")
+        self.in_features = int(linear.in_features)
+        self.out_features = int(linear.out_features)
+        self.rank = int(rank)
+        self.alpha = float(alpha)
+        self.scaling = float(alpha) / float(rank)
+        self.weight = nn.Parameter(linear.weight.detach().clone(), requires_grad=False)
+        if linear.bias is None:
+            self.register_parameter("bias", None)
+        else:
+            self.bias = nn.Parameter(linear.bias.detach().clone(), requires_grad=False)
+        self.lora_A = nn.Parameter(
+            torch.empty(
+                self.rank,
+                self.in_features,
+                dtype=linear.weight.dtype,
+                device=linear.weight.device,
+            )
+        )
+        self.lora_B = nn.Parameter(
+            torch.zeros(
+                self.out_features,
+                self.rank,
+                dtype=linear.weight.dtype,
+                device=linear.weight.device,
+            )
+        )
+        self.dropout = nn.Dropout(float(dropout)) if dropout > 0 else nn.Identity()
+        nn.init.kaiming_uniform_(self.lora_A, a=math.sqrt(5))
+
+    def forward(self, input_tensor: torch.Tensor) -> torch.Tensor:
+        base_weight = self.weight
+        base_bias = self.bias
+        if input_tensor.is_floating_point():
+            base_weight = base_weight.to(dtype=input_tensor.dtype)
+            if base_bias is not None:
+                base_bias = base_bias.to(dtype=input_tensor.dtype)
+        result = F.linear(input_tensor, base_weight, base_bias)
+        lora_input = self.dropout(input_tensor)
+        lora_A = self.lora_A.to(dtype=lora_input.dtype)
+        lora_B = self.lora_B.to(dtype=lora_input.dtype)
+        update = F.linear(F.linear(lora_input, lora_A), lora_B) * self.scaling
+        return result + update.to(dtype=result.dtype)
+
+    def _merged_weight(self) -> torch.Tensor:
+        delta = torch.matmul(self.lora_B, self.lora_A) * self.scaling
+        return self.weight + delta.to(dtype=self.weight.dtype)
+
+    def _save_to_state_dict(self, destination, prefix, keep_vars):
+        weight = self._merged_weight()
+        destination[prefix + "weight"] = weight if keep_vars else weight.detach()
+        if self.bias is not None:
+            destination[prefix + "bias"] = self.bias if keep_vars else self.bias.detach()
+
+    def extra_repr(self) -> str:
+        return (
+            f"in_features={self.in_features}, out_features={self.out_features}, "
+            f"rank={self.rank}, alpha={self.alpha}"
+        )
+
+
+def _module_name_matches(full_name: str, prefixes: tuple[str, ...]) -> bool:
+    return any(full_name.startswith(prefix) for prefix in prefixes)
+
+
+def _inject_lora_adapters(
+    model: nn.Module,
+    *,
+    module_patterns: list[str],
+    target_module_names: list[str],
+    rank: int,
+    alpha: float,
+    dropout: float,
+) -> tuple[int, int]:
+    prefixes = tuple(str(pattern) for pattern in module_patterns)
+    target_names = {str(name) for name in target_module_names}
+    replacements: list[tuple[nn.Module, str, nn.Linear, str]] = []
+    for parent_name, parent in model.named_modules():
+        for child_name, child in list(parent.named_children()):
+            if not isinstance(child, nn.Linear):
+                continue
+            full_name = f"{parent_name}.{child_name}" if parent_name else child_name
+            if not _module_name_matches(full_name, prefixes):
+                continue
+            if child_name not in target_names:
+                continue
+            replacements.append((parent, child_name, child, full_name))
+
+    for parent, child_name, child, _full_name in replacements:
+        setattr(
+            parent,
+            child_name,
+            _MergedLoRALinear(
+                child,
+                rank=rank,
+                alpha=alpha,
+                dropout=dropout,
+            ),
+        )
+
+    trainable_parameters = 0
+    for param in model.parameters():
+        if param.requires_grad:
+            trainable_parameters += int(param.numel())
+    return len(replacements), trainable_parameters
+
